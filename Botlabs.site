Bot not responding Need help coding Looking for testers Ask in Discord const pages = ['home', 'browse', 'submit', 'help']; const botList = document.getElementById('botList'); function showPage(id) { pages.forEach(p => document.getElementById(p).classList.add('hidden')); document.getElementById(id).classList.remove('hidden'); if (id === 'browse') renderBots(); } function getBots() { return JSON.parse(localStorage.getItem('bots') || '[]'); } function addBot() { const bots = getBots(); bots.push({ name: name.value, desc: desc.value, cat: cat.value, link: link.value }); localStorage.setItem('bots', JSON.stringify(bots)); alert('Bot submitted! (local demo)'); name.value = desc.value = link.value = ''; } function renderBots() { const bots = getBots(); botList.innerHTML = bots.length ? '' : '

No bots yet.

'; bots.forEach(b => { const div = document.createElement('div'); div.className = 'card'; div.innerHTML = `${b.name}

${b.desc}

