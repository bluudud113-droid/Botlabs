BotLab body { margin: 0; font-family: Arial, Helvetica, sans-serif; background: #0f1220; color: #eaeaf0; } header { padding: 20px; text-align: center; background: #151935; } header h1 { margin: 0; } nav { display: flex; justify-content: center; gap: 15px; margin-top: 10px; } nav button { background: #2a2f6f; border: none; color: white; padding: 8px 14px; border-radius: 6px; cursor: pointer; } nav button:hover { background: #3b41a5; } main { padding: 20px; max-width: 900px; margin: auto; } .hidden { display: none; } .card { background: #1a1f45; padding: 15px; border-radius: 8px; margin-bottom: 10px; } label { display: block; margin-top: 10px; } input, textarea, select { width: 100%; padding: 8px; margin-top: 4px; border-radius: 6px; border: none; } .btn { margin-top: 15px; background: #5865f2; border: none; padding: 10px 16px; color: white; border-radius: 6px; cursor: pointer; } .btn:hover { background: #4752c4; } BotLab 🧪 

